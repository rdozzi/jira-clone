<table
  width='100%'
  cellpadding='0'
  cellspacing='0'
  style='background-color:#FAFBFC; padding:40px 0;'
>
  <tr>
    <td align='center'>

      <table
        width='600'
        cellpadding='0'
        cellspacing='0'
        style="background:#FFFFFF; border:1px solid #DADADA; border-radius:8px; padding:40px; font-family:'Inter', Arial, sans-serif; color:#1F2937;"
      >

        <!-- Title -->
        <tr>
          <td style='font-size:20px; font-weight:600; padding-bottom:24px;'>
            Reset Your Password
          </td>
        </tr>

        <!-- Greeting -->
        <tr>
          <td style='font-size:16px; line-height:1.6;'>
            Hello
            {{firstName}},
          </td>
        </tr>

        <!-- Message -->
        <tr>
          <td style='padding-top:16px; font-size:16px; line-height:1.6;'>
            We received a request to reset your password. Click the button below
            to choose a new one.
          </td>
        </tr>

        <!-- Button -->
        <tr>
          <td align='center' style='padding:32px 0;'>
            <a
              href='{{link}}'
              style='background-color:#5154F0;
                      color:#FFFFFF;
                      text-decoration:none;
                      padding:12px 24px;
                      border-radius:8px;
                      display:inline-block;
                      font-size:16px;
                      font-weight:500;'
            >
              Reset Password
            </a>
          </td>
        </tr>

        <!-- Expiration -->
        <tr>
          <td style='font-size:14px; color:#6B7280; line-height:1.6;'>
            This link will expire in
            {{expiresIn}}
            minutes.
          </td>
        </tr>

        <!-- Footer -->
        <tr>
          <td style='padding-top:32px; font-size:12px; color:#9CA3AF;'>
            If you did not request this change, you can safely ignore this
            email.
          </td>
        </tr>

        <tr>
          <td style='padding-top:16px; font-size:12px; color:#9CA3AF;'>
            ©
            {{year}}
            JiraClone
          </td>
        </tr>

      </table>

    </td>
  </tr>
</table>